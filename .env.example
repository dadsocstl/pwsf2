# .env.example
# Copy this file to .env and populate values before running CyberForge scripts.
# DO NOT commit .env with real secrets.

# ---------------------------------------------------------------------------
# Cluster / Infrastructure
# ---------------------------------------------------------------------------
KUBECONFIG=/path/to/kubeconfig
KUBE_CONTEXT=cyberforge-prod
TERRAFORM_WORKSPACE=prod
TF_VAR_cluster_name=cyberforge
TF_VAR_region=us-gov-west-1

# ---------------------------------------------------------------------------
# Internal Registry (IronBank mirror or on-prem Harbor)
# ---------------------------------------------------------------------------
REGISTRY_URL=registry.example.mil
REGISTRY_USERNAME=svc-cyberforge
REGISTRY_PASSWORD=CHANGEME

# ---------------------------------------------------------------------------
# Vault
# ---------------------------------------------------------------------------
VAULT_ADDR=https://vault.example.mil:8200
VAULT_TOKEN=CHANGEME
VAULT_NAMESPACE=cyberforge

# ---------------------------------------------------------------------------
# ArgoCD
# ---------------------------------------------------------------------------
ARGOCD_SERVER=argocd.example.mil
ARGOCD_AUTH_TOKEN=CHANGEME

# ---------------------------------------------------------------------------
# Cosign / Supply-chain signing
# ---------------------------------------------------------------------------
COSIGN_KEY_PATH=/path/to/cosign.key
COSIGN_PASSWORD=CHANGEME
SIGSTORE_NO_TLOG_UPLOAD=true   # set true in air-gapped environments

# ---------------------------------------------------------------------------
# OSCAL / compliance-trestle
# ---------------------------------------------------------------------------
TRESTLE_WORKSPACE=oscal-compliance/trestle-workspace

# ---------------------------------------------------------------------------
# Notifications / Alerting
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGEME
ALERT_EMAIL=security@example.mil

# ---------------------------------------------------------------------------
# Air-gap overrides
# ---------------------------------------------------------------------------
# Override base URLs to point at internal mirrors in disconnected environments.
MIRROR_BASE=https://registry.example.mil/artifacts
NIST_OSCAL_BASE=https://repo.example.mil/nist-oscal